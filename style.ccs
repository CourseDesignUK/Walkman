<div class="walkman-container">
    <img src="walkman-body.png" class="walkman-base" alt="Sony Walkman">

    <div class="spool-overlay">
        <img src="spool.png" id="spool-l" class="spool-img">
        <img src="spool.png" id="spool-r" class="spool-img">
    </div>

    <audio id="audio-player" src="music.mp3"></audio>

    <button id="play-btn" class="invisible-hotspot"></button>
</div>
